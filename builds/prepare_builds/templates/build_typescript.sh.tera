#! /bin/sh

mkdir -p ./pkg/src
cp -r ../../src.ts/* pkg/src/.
rm -f ./pkg/raw.ts
echo 'export * from "./vectorg_engine_wasm{{ dimension }}d"' > pkg/src/raw.ts
# See https://serverfault.com/a/137848
find pkg/ -type f -print0 | LC_ALL=C xargs -0 sed -i.bak '\:#if DIM{% if dimension == "2" %}3{% else %}2{% endif %}:,\:#endif:d'
npx tsc
# NOTE: we keep the typescripts files into the NPM package for source mapping: see #3
sed -i.bak 's/"module": "vectorg_engine_wasm{{ dimension }}d.js"/"module": "vectorg-engine.js"/g' pkg/package.json
sed -i.bak 's/"types": "vectorg_engine_wasm{{ dimension }}d.d.ts"/"types": "vectorg-engine.d.ts"/g' pkg/package.json
find pkg/ -type f -name '*.bak' | xargs rm
